extends layout

block content
  h1 Flashcard App

  p.lead A simple study tool for flashcards, decks, and multiple‑choice questions.

  // Summary cards
  .row.mt-4
    .col-md-4
      .card.text-bg-light.mb-3
        .card-header Summary
        .card-body
          h5.card-title Decks
          p.card-text #{deck_count} total
          a.btn.btn-primary(href='/decks') View Decks

    .col-md-4
      .card.text-bg-light.mb-3
        .card-header Summary
        .card-body
          h5.card-title Flashcards
          p.card-text #{card_count} total
          a.btn.btn-primary(href='/cards') View Cards

    .col-md-4
      .card.text-bg-light.mb-3
        .card-header Summary
        .card-body
          h5.card-title Multiple Choice Questions
          p.card-text #{mcq_count} total
          a.btn.btn-primary(href='/multiple-choice') View MCQs

  hr

  h3 Quick Actions
  .row.mt-3
    .col-md-4
      a.btn.btn-success.w-100(href='/decks/create') Create New Deck
    .col-md-4
      a.btn.btn-success.w-100(href='/cards/create') Create New Flashcard
    .col-md-4
      a.btn.btn-success.w-100(href='/multiple-choice/create') Create New MCQ

