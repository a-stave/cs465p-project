extends layout 

block content 
  h1 #{title}: #{card.question}

  if decks && decks.length
    p
      strong This card belongs to the following decks. Remove it from these decks before deleting:
    ul
      each deck in decks
        li
          a(href=deck.url)= deck.name
          if deck.description
            |  — #{deck.description}

  else
    p Do you really want to delete this card?

    form(method='POST')
      input(type='hidden', name='cardid', value=card.id)
      button.btn.btn-primary(type='submit') Delete
