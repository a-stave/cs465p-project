extends ../layout 

block content 
  section.page-container.form-panel
    //- Return to list page
    a.back-link(href=backUrl)
      i.bi.bi-chevron-left  Back to All Flashcards

    h1= title 

    //- Use checkboxes to specify decks so this card can be shared by multiple decks
    form(method='POST')
      div.form-group
        label(for='question') Question:
        input#question.form-control(
          type='text'
          name='question'
          required
          value=(card ? card.question : '')
        )

      div.form-group
        label(for='answer') Answer:
        textarea#answer.form-control(
          name='answer'
          required
        )= card ? card.answer : ''

      if decks && decks.length
        fieldset.form-group
          legend Decks
          div
            each deck in decks
              div.form-check
                input.form-check-input(
                  type='checkbox'
                  id='deck-' + deck.id
                  name='decks'
                  value=deck.id
                  checked=deck.checked
                )
                label.form-check-label(for='deck-' + deck.id)= deck.name

      div.form-actions
        button#submit-button(type='submit') Submit

    if errors
      ul
        each error in errors
          li= error.msg
