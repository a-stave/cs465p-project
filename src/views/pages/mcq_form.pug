extends ../layout

block content
  section.page-container.form-panel
    //- Return to list page
    a.back-link(href=backUrl)
      i.bi.bi-chevron-left  Back to All Multiple Choice

    h1= title

    //- Use checkboxes to specify decks so this MCQ can be shared by multiple decks
    form(method='POST')
      div.form-group
        label(for='question') Question:
        input#question.form-control(
          type='text'
          name='question'
          required
          value=(mcq ? mcq.question : '')
        )

      div.form-group
        label(for='options') Options (one per line):
        textarea#options.form-control(
          name='options'
          required
        )= mcq ? mcq.options.join('\n') : ''

      div.form-group
        label(for='correctAnswer') Correct Answer:
        input#correctAnswer.form-control(
          type='text'
          name='correctAnswer'
          required
          value=(mcq ? mcq.correctAnswer : '')
        )

      div.form-group
        label(for='imageUrl') Image URL (optional):
        input#imageUrl.form-control(
          type='text'
          name='imageUrl'
          value=(mcq ? mcq.imageUrl : '')
        )

      if decks.length
        h3 Decks
        each deck in decks
          div.form-check
            input.form-check-input(
              type='checkbox'
              id='deck-' + deck.id
              name='decks'
              value=deck.id
              checked=deck.checked
            )
            label.form-check-label(for='deck-' + deck.id)= deck.name

      div.form-actions
        button#submit-button(type='submit') Submit

    if errors
      ul
        each error in errors
          li= error.msg
